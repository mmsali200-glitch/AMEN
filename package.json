{
  "name": "cfo-intelligence-system",
  "version": "4.0.0",
  "description": "المستشار المالي - CFO Intelligence System",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite client",
    "build": "vite build",
    "start": "node -e \"require('child_process').execSync('npx tsx server/seed.ts', {stdio:'inherit'})\" && npx tsx server/index.ts",
    "start:prod": "npm run build && npx tsx server/seed.ts && npx tsx server/index.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx server/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.44.7",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "superjson": "^2.2.1",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.29.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.30.0",
    "framer-motion": "^11.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.12.7",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "wouter": "^3.3.0"
  }
}
